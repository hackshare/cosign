# Copy to .env.devnet or set COSIGN_ENV_FILE=/path/to/file.
# Do not commit real RPC credentials.

# Helius devnet RPC URL, usually including the api-key query parameter.
COSIGN_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=<helius-api-key>

# Optional read fixtures.
COSIGN_DEVNET_MEMBER=
COSIGN_DEVNET_MULTISIG=
COSIGN_DEVNET_PROPOSAL_INDEX=

# Set to 1 to discover any devnet Squad when COSIGN_DEVNET_MULTISIG is unset.
COSIGN_DEVNET_DISCOVER_MULTISIG=0
